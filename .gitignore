# ============================================================
# Dependencies
# ============================================================
# Node modules are huge and reproducible from package.json
node_modules/

# ============================================================
# Environment files (SECRETS — never commit)
# ============================================================
# Real env files contain credentials, API keys, etc.
.env
.env.local
.env.*.local

# We DO want to commit a template that shows which vars exist
!.env.example

# ============================================================
# Build output
# ============================================================
# Compiled TypeScript, bundled frontend, etc.
dist/
build/
*.tsbuildinfo

# ============================================================
# Logs
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ============================================================
# OS-specific junk
# ============================================================
# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# ============================================================
# Editor / IDE state (per-developer, not shared)
# ============================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================
# Coverage and test artifacts (not used yet, but ready)
# ============================================================
coverage/
.nyc_output/
