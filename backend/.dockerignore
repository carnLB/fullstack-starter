# ============================================================
# Files NOT copied into the Docker build context.
# Mirrors most of the project's .gitignore plus a few extras.
# ============================================================

# Dependencies — installed inside the image by `npm install`
node_modules/

# Build artifacts — regenerated inside the image
dist/

# Environment files — mounted at runtime via docker-compose
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Editor / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git metadata
.git/
.gitignore
.gitattributes
