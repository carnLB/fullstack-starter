# EditorConfig — https://editorconfig.org
# Top-most EditorConfig file: stop searching parent directories
root = true

# ============================================================
# Defaults for every file in the repo
# ============================================================
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# ============================================================
# Markdown — two trailing spaces mean "hard line break",
# so we must NOT trim them.
# ============================================================
[*.md]
trim_trailing_whitespace = false

# ============================================================
# YAML — 2 spaces is the universal convention.
# Aligns with Prettier's YAML override.
# ============================================================
[*.{yml,yaml}]
indent_size = 2
